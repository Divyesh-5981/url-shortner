<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>URL Shortener</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				font-family: "Inter", sans-serif;
				background: #0a0a0a;
				color: #ededed;
				min-height: 100vh;
				padding: 60px 20px;
			}

			.container {
				max-width: 860px;
				margin: 0 auto;
			}

			.header {
				margin-bottom: 48px;
			}

			.header .badge {
				display: inline-block;
				background: #1a1a1a;
				color: #a3a3a3;
				border: 1px solid #2a2a2a;
				font-size: 0.75rem;
				font-weight: 500;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				padding: 4px 12px;
				border-radius: 20px;
				margin-bottom: 16px;
			}

			.header h1 {
				font-size: 2.8rem;
				font-weight: 700;
				color: #ffffff;
				line-height: 1.15;
				letter-spacing: -0.03em;
				margin-bottom: 10px;
			}

			.header p {
				color: #737373;
				font-size: 1.05rem;
				font-weight: 400;
			}

			.success-banner {
				background: #0d1f12;
				border: 1px solid #1a3a22;
				border-radius: 10px;
				padding: 14px 18px;
				margin-bottom: 28px;
				display: flex;
				align-items: center;
				gap: 10px;
				font-size: 0.9rem;
			}

			.success-banner span {
				color: #4ade80;
				font-weight: 500;
			}

			.success-banner a {
				color: #86efac;
				font-weight: 600;
				word-break: break-all;
			}

			.form-card {
				background: #111111;
				border: 1px solid #1f1f1f;
				border-radius: 14px;
				padding: 28px;
				margin-bottom: 40px;
			}

			.form-card label {
				display: block;
				font-size: 0.82rem;
				color: #737373;
				margin-bottom: 10px;
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}

			.input-row {
				display: flex;
				gap: 10px;
			}

			.form-card input[type="text"] {
				flex: 1;
				background: #0a0a0a;
				border: 1px solid #2a2a2a;
				border-radius: 8px;
				padding: 13px 16px;
				color: #ededed;
				font-size: 0.95rem;
				font-family: "Inter", sans-serif;
				outline: none;
				transition: border-color 0.15s, box-shadow 0.15s;
			}

			.form-card input[type="text"]:focus {
				border-color: #525252;
				box-shadow: 0 0 0 3px rgba(255,255,255,0.04);
			}

			.form-card input[type="text"]::placeholder {
				color: #404040;
			}

			.form-card button {
				background: #ededed;
				color: #0a0a0a;
				border: none;
				border-radius: 8px;
				padding: 13px 24px;
				font-size: 0.9rem;
				font-weight: 600;
				font-family: "Inter", sans-serif;
				cursor: pointer;
				transition: background 0.15s, transform 0.1s;
				white-space: nowrap;
				letter-spacing: -0.01em;
			}

			.form-card button:hover {
				background: #ffffff;
				transform: translateY(-1px);
			}

			.form-card button:active {
				transform: translateY(0);
			}

			.table-section-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 14px;
			}

			.table-section-header h2 {
				font-size: 0.82rem;
				color: #737373;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}

			.table-section-header .count {
				font-size: 0.8rem;
				color: #525252;
				font-weight: 500;
			}

			.table-wrapper {
				background: #111111;
				border: 1px solid #1f1f1f;
				border-radius: 14px;
				overflow: hidden;
			}

			table {
				width: 100%;
				border-collapse: collapse;
			}

			thead th {
				padding: 12px 20px;
				text-align: left;
				font-size: 0.78rem;
				color: #525252;
				text-transform: uppercase;
				letter-spacing: 0.07em;
				font-weight: 600;
				background: #0d0d0d;
				border-bottom: 1px solid #1f1f1f;
			}

			tbody tr {
				border-bottom: 1px solid #1a1a1a;
				transition: background 0.1s;
			}

			tbody tr:last-child {
				border-bottom: none;
			}

			tbody tr:hover {
				background: #161616;
			}

			tbody td {
				padding: 14px 20px;
				font-size: 0.88rem;
				color: #a3a3a3;
				vertical-align: middle;
			}

			tbody td:first-child {
				color: #333333;
				font-weight: 600;
				font-size: 0.8rem;
				width: 50px;
			}

			.short-url {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				background: #1a1a1a;
				border: 1px solid #2a2a2a;
				border-radius: 6px;
				padding: 4px 10px;
				font-size: 0.85rem;
				font-weight: 500;
				color: #ededed;
				text-decoration: none;
				transition: background 0.15s, border-color 0.15s;
				font-family: "Inter", monospace;
			}

			.short-url:hover {
				background: #222222;
				border-color: #404040;
			}

			.original-url {
				color: #737373;
				text-decoration: none;
				font-size: 0.85rem;
				transition: color 0.15s;
				display: block;
				max-width: 320px;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.original-url:hover {
				color: #a3a3a3;
			}

			.clicks-badge {
				display: inline-flex;
				align-items: center;
				gap: 4px;
				background: #1a1a1a;
				color: #737373;
				border-radius: 20px;
				padding: 3px 10px;
				font-size: 0.8rem;
				font-weight: 500;
			}

			.empty-state {
				text-align: center;
				padding: 64px 20px;
				color: #404040;
			}

			.empty-state .icon {
				font-size: 2rem;
				margin-bottom: 12px;
			}

			.empty-state p {
				font-size: 0.95rem;
				font-weight: 400;
			}
		</style>
	</head>
	<body>
		<div class="container">

			<div class="header">
				<div class="badge">Free & Open Source</div>
				<h1>Shorten any URL,<br/>instantly.</h1>
				<p>Paste a long link and get a clean, shareable short URL.</p>
			</div>

			<% if (locals.shortId) { %>
				<div class="success-banner">
					<span>✓ Short URL ready —</span>
					<a href="http://localhost:8000/api/urls/<%= locals.shortId %>" target="_blank">
						localhost:8000/api/urls/<%= locals.shortId %>
					</a>
				</div>
			<% } %>

			<div class="form-card">
				<label for="url">Your long URL</label>
				<form action="/api/urls" method="post">
					<div class="input-row">
						<input
							id="url"
							type="text"
							name="url"
							placeholder="https://example.com/some/very/long/link"
							autocomplete="off"
						/>
						<button type="submit">Shorten →</button>
					</div>
				</form>
			</div>

			<% if (locals.urls && locals.urls.length > 0) { %>
				<div class="table-section-header">
					<h2>Recent URLs</h2>
					<span class="count"><%= urls.length %> links</span>
				</div>
				<div class="table-wrapper">
					<table>
						<thead>
							<tr>
								<th>#</th>
								<th>Short URL</th>
								<th>Original URL</th>
								<th>Clicks</th>
							</tr>
						</thead>
						<tbody>
							<% urls.forEach((url, index) => { %>
								<tr>
									<td><%= index + 1 %></td>
									<td>
										<a class="short-url" href="http://localhost:8000/api/urls/<%= url.shortId %>" target="_blank">
											/<%= url.shortId %>
										</a>
									</td>
									<td>
										<a class="original-url" href="<%= url.redirectURL %>" target="_blank" title="<%= url.redirectURL %>">
											<%= url.redirectURL %>
										</a>
									</td>
									<td>
										<span class="clicks-badge">
											<%= url.visitHistory.length %> clicks
										</span>
									</td>
								</tr>
							<% }) %>
						</tbody>
					</table>
				</div>
			<% } else if (locals.urls && locals.urls.length === 0) { %>
				<div class="table-wrapper">
					<div class="empty-state">
						<div class="icon">🔗</div>
						<p>No URLs yet. Paste one above to get started.</p>
					</div>
				</div>
			<% } %>

		</div>
	</body>
</html>
