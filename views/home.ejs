<!DOCTYPE html>
<html lang="en">
	<%- include('partials/head') %>
	<body>
		<div class="container">

			<div class="header">
				<div class="badge">Free & Open Source</div>
				<h1>Shorten any URL,<br/>instantly.</h1>
				<p>Paste a long link and get a clean, shareable short URL.</p>
			</div>

			<% if (locals.shortId) { %>
				<div class="success-banner">
					<span>✓ Short URL ready —</span>
					<a href="http://localhost:8000/api/urls/<%= locals.shortId %>" target="_blank">
						localhost:8000/api/urls/<%= locals.shortId %>
					</a>
				</div>
			<% } %>

			<div class="form-card">
				<label for="url">Your long URL</label>
				<form action="/api/urls" method="post">
					<div class="input-row">
						<input
							id="url"
							type="text"
							name="url"
							placeholder="https://example.com/some/very/long/link"
							autocomplete="off"
						/>
						<button type="submit">Shorten →</button>
					</div>
				</form>
			</div>

			<% if (locals.urls && locals.urls.length > 0) { %>
				<div class="table-section-header">
					<h2>Recent URLs</h2>
					<span class="count"><%= urls.length %> links</span>
				</div>
				<div class="table-wrapper">
					<table>
						<thead>
							<tr>
								<th>#</th>
								<th>Short URL</th>
								<th>Original URL</th>
								<% if (locals.showCreator) { %>
									<th>Created By</th>
								<% } %>
								<th>Clicks</th>
							</tr>
						</thead>
						<tbody>
							<% urls.forEach((url, index) => { %>
								<tr>
									<td><%= index + 1 %></td>
									<td>
										<a class="short-url" href="http://localhost:8000/api/urls/<%= url.shortId %>" target="_blank">
											/<%= url.shortId %>
										</a>
									</td>
									<td>
										<a class="original-url" href="<%= url.redirectURL %>" target="_blank" title="<%= url.redirectURL %>">
											<%= url.redirectURL %>
										</a>
									</td>
									<% if (locals.showCreator) { %>
										<td>
											<%= url.createdBy?.name || url.createdBy?.email || "Unknown user" %>
										</td>
									<% } %>
									<td>
										<span class="clicks-badge">
											<%= url.visitHistory.length %> clicks
										</span>
									</td>
								</tr>
							<% }) %>
						</tbody>
					</table>
				</div>
			<% } else if (locals.urls && locals.urls.length === 0) { %>
				<div class="table-wrapper">
					<div class="empty-state">
						<div class="icon">🔗</div>
						<p>No URLs yet. Paste one above to get started.</p>
					</div>
				</div>
			<% } %>

		</div>
	</body>
</html>
